-- 稳定全自动版（2~3秒换服，带错误恢复，自动重连）
local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local TweenService = game:GetService("TweenService")
local player = Players.LocalPlayer
local placeId = game.PlaceId
local currentJobId = game.JobId

-- 配置（你可以把 Min/Max 改回 0.9/1.1 变回1秒）
local CONFIG = {
    MinInterval = 2,    -- 最小间隔（秒）
    MaxInterval = 3,    -- 最大间隔（秒）
    TweenDuration = 0.4,
    PickupDelay = 0.1,
    Offset = Vector3.new(1.2, 0, 0)
}

-- 黑名单（强过滤）
local BLACKLIST = {"shop","store","menu","health","mobile","play","character","backpack",
                   "生命","移动","商店","健康","r-mobile","血包","医疗","vending"}

-- 状态UI（显示在左上角）
local function createUI()
    local gui = Instance.new("ScreenGui")
    gui.Parent = player:WaitForChild("PlayerGui")
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0, 300, 0, 50)
    lbl.Position = UDim2.new(0, 10, 0, 10)
    lbl.BackgroundColor3 = Color3.fromRGB(0,0,0)
    lbl.BackgroundTransparency = 0.5
    lbl.TextColor3 = Color3.fromRGB(255,255,255)
    lbl.TextScaled = true
    lbl.Text = "启动中..."
    lbl.Parent = gui
    return lbl
end
local statusLabel = createUI()
local function setStatus(t) pcall(function() statusLabel.Text = t end) end

setStatus("脚本加载中...")

-- 防封清除UI
local function cleanAntiCheat()
    for _,r in pairs({player:WaitForChild("PlayerGui"), game:GetService("CoreGui")}) do
        for _,v in pairs(r:GetChildren()) do
            local n = v.Name:lower()
            if n:find("anti") or n:find("cheat") or n:find("ban") or n:find("sec") or n:find("moder") then
                pcall(function() v:Destroy() end)
            end
        end
    end
end

-- 搜索目标（只认名字同时含 "money" 和 "printer"）
local function findTarget()
    local target = nil
    local function search(inst)
        if target then return end
        local path = inst:GetFullName():lower()
        for _,w in pairs(BLACKLIST) do if path:find(w) then return end end
        if inst:IsA("BasePart") or inst:IsA("Model") or inst:IsA("Tool") then
            local name = inst.Name:lower()
            if name:find("money") and name:find("printer") then
                local click = inst:FindFirstChild("ClickDetector") or inst:FindFirstChildOfClass("ClickDetector")
                if click or inst:IsA("Tool") then target = inst return end
            end
        end
        for _,c in pairs(inst:GetChildren()) do search(c) if target then return end end
    end
    pcall(search, workspace)
    return target
end

-- 拾取函数
local function collect()
    local t = findTarget()
    if not t then setStatus("❌ 未找到"); return false end
    local pos = nil
    if t:IsA("Model") and t.PrimaryPart then pos = t.PrimaryPart.Position
    elseif t:IsA("BasePart") then pos = t.Position
    elseif t:IsA("Tool") and t:FindFirstChild("Handle") then pos = t.Handle.Position
    else
        for _,c in pairs(t:GetDescendants()) do if c:IsA("BasePart") then pos = c.Position break end end
    end
    if not pos then return false end
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return false end
    local hrp = char.HumanoidRootPart
    local cf = CFrame.new(pos + CONFIG.Offset)
    setStatus("🚀 传送中...")
    local tw = TweenService:Create(hrp, TweenInfo.new(CONFIG.TweenDuration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {CFrame=cf})
    tw:Play(); tw.Completed:Wait(); wait(CONFIG.PickupDelay)
    local cd = t:FindFirstChild("ClickDetector") or t:FindFirstChildOfClass("ClickDetector")
    if cd then pcall(function() cd:FireClick(player) end); setStatus("✅ 拾取成功!"); return true end
    if t:IsA("Tool") then
        local h = char:FindFirstChild("Humanoid")
        if h then pcall(function() h:EquipTool(t) end); setStatus("✅ 装备成功!"); return true end
    end
    setStatus("✅ 已靠近")
    return true
end

-- 换服
local function hop()
    setStatus("🔄 换服中...")
    local servers = {}
    local ok, res = pcall(function() return TeleportService:GetServerList(placeId) end)
    if ok and res then
        for _,s in pairs(res) do
            if s.Id ~= currentJobId and s.PlayerCount < s.MaxPlayers then table.insert(servers, s) end
        end
    end
    if #servers > 0 then
        local t = servers[math.random(#servers)]
        pcall(function() TeleportService:TeleportToPlaceInstance(placeId, t.Id, player) end)
    else
        pcall(function() TeleportService:TeleportToPlaceInstance(placeId, currentJobId, player) end)
    end
end

-- ===== 主循环（带错误恢复和重启机制） =====
local function mainLoop()
    while true do
        local success, err = pcall(function()
            -- 等待角色加载
            repeat wait(0.3) until player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            wait(0.5)
            -- 执行拾取
            collect()
            -- 随机间隔
            local wt = math.random(CONFIG.MinInterval*10, CONFIG.MaxInterval*10)/10
            setStatus("⏳ "..string.format("%.1f", wt).."秒后换服")
            wait(wt)
            -- 换服
            hop()
            currentJobId = game.JobId
            wait(0.3)
        end)
        if not success then
            -- 如果发生错误，记录并重启循环
            print("⚠️ 检测到错误，重启循环: " .. tostring(err))
            setStatus("⚠️ 错误重启中...")
            wait(2)  -- 等待2秒再继续
        end
    end
end

-- 启动
spawn(function()
    cleanAntiCheat()
    -- 延迟一小会儿再启动
    wait(1)
    print("🔥 稳定版启动，间隔 "..CONFIG.MinInterval.."~"..CONFIG.MaxInterval.." 秒")
    setStatus("✅ 启动成功")
    mainLoop()
end)

print("🔥 稳定版脚本已加载，如遇错误会自动重启。")
