-- 基础防检测混淆延迟加载层
local task = task
local wait = task.wait
local spawn = task.spawn
local delay = task.delay
local new = Instance.new
local getSvc = game:GetService

-- 延迟初始化，规避上线即时扫描
delay(0.25, function()
    local Players = getSvc("Players")
    local RunService = getSvc("RunService")
    local UserInputService = getSvc("UserInputService")
    local Workspace = getSvc("Workspace")
    local CoreGui = Players.LocalPlayer:WaitForChild("PlayerGui")

    -- 随机命名防特征检测
    local g1 = new("ScreenGui")
    g1.Name = tostring(math.random(1000,9999))
    g1.ResetOnSpawn = false
    g1.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    g1.Parent = CoreGui

    local g2 = new("ScreenGui")
    g2.Name = tostring(math.random(1000,9999))
    g2.ResetOnSpawn = false
    g2.AlwaysOnTop = true
    g2.Parent = CoreGui

    -- 功能变量
    local AimbotEnable = false
    local LockMode = "Head"
    local AimRange = 300
    local PanelShow = false
    local localChar, localHRP

    -- 角色刷新
    local function RefreshSelf()
        localChar = Players.LocalPlayer.Character or Players.LocalPlayer.CharacterAdded:Wait()
        localHRP = localChar:WaitForChild("HumanoidRootPart")
    end
    RefreshSelf()
    Players.LocalPlayer.CharacterAdded:Connect(RefreshSelf)

    -- 可拖动圆形悬浮按钮
    local FloatBtn = new("TextButton")
    FloatBtn.Size = UDim2.new(0, 60, 0, 60)
    FloatBtn.Position = UDim2.new(0.84, 0, 0.3, 0)
    FloatBtn.BackgroundColor3 = Color3.new(0.1,0.1,0.1)
    FloatBtn.BorderSizePixel = 3
    FloatBtn.BorderColor3 = Color3.new(0.7,0.7,0.7)
    FloatBtn.Text = "瞄准"
    FloatBtn.TextColor3 = Color3.new(1,1,1)
    FloatBtn.Font = Enum.Font.SourceSansBold
    FloatBtn.TextSize = 16
    FloatBtn.Active = true
    FloatBtn.ZIndex = 999
    FloatBtn.Parent = g1

    local dragStart, btnOrigin, isDrag
    FloatBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            dragStart = input.Position
            btnOrigin = FloatBtn.Position
            isDrag = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragStart and input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - dragStart
            if math.abs(delta.X) > 12 or math.abs(delta.Y) > 12 then
                isDrag = true
                FloatBtn.Position = UDim2.new(btnOrigin.X.Scale, btnOrigin.X.Offset + delta.X, btnOrigin.Y.Scale, btnOrigin.Y.Offset + delta.Y)
            end
        end
    end)
    FloatBtn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch and not isDrag then
            PanelShow = not PanelShow
            SettingPanel.Visible = PanelShow
        end
        dragStart, isDrag = nil, false
    end)

    -- 设置面板
    local SettingPanel = new("Frame")
    SettingPanel.Size = UDim2.new(0, 260, 0, 280)
    SettingPanel.Position = UDim2.new(0.02,0,0.2,0)
    SettingPanel.BackgroundColor3 = Color3.new(0.08,0.08,0.08)
    SettingPanel.BorderSizePixel = 3
    SettingPanel.BorderColor3 = Color3.new(0.4,0.4,0.4)
    SettingPanel.Visible = false
    SettingPanel.Active = true
    SettingPanel.Parent = g1

    local Title = new("TextLabel")
    Title.Size = UDim2.new(0,240,0,26)
    Title.Position = UDim2.new(0,10,0,6)
    Title.BackgroundTransparency = 1
    Title.TextColor3 = Color3.new(1,1,1)
    Title.Font = Enum.Font.SourceSansBold
    Title.TextSize = 18
    Title.Text = "范围瞄准设置"
    Title.Parent = SettingPanel

    -- 总开关
    local MainSwitch = new("TextButton")
    MainSwitch.Size = UDim2.new(0,240,0,34)
    MainSwitch.Position = UDim2.new(0,10,0,40)
    MainSwitch.BackgroundColor3 = Color3.new(0.2,0.2,0.2)
    MainSwitch.TextColor3 = Color3.new(1,1,1)
    MainSwitch.Text = "瞄准功能：关闭"
    MainSwitch.Font = Enum.Font.SourceSans
    MainSwitch.TextSize = 16
    MainSwitch.Active = true
    MainSwitch.Parent = SettingPanel
    MainSwitch.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            AimbotEnable = not AimbotEnable
            MainSwitch.Text = AimbotEnable and "瞄准功能：开启" or "瞄准功能：关闭"
            MainSwitch.BackgroundColor3 = AimbotEnable and Color3.new(0,0.4,0) or Color3.new(0.2,0.2,0.2)
        end
    end)

    -- 头部/身体切换
    local ModeBtn = new("TextButton")
    ModeBtn.Size = UDim2.new(0,240,0,34)
    ModeBtn.Position = UDim2.new(0,10,0,82)
    ModeBtn.BackgroundColor3 = Color3.new(0.2,0.2,0.2)
    ModeBtn.TextColor3 = Color3.new(1,1,1)
    ModeBtn.Text = "锁定目标：头部"
    ModeBtn.Font = Enum.Font.SourceSans
    ModeBtn.TextSize = 16
    ModeBtn.Active = true
    ModeBtn.Parent = SettingPanel
    ModeBtn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            LockMode = LockMode == "Head" and "Torso" or "Head"
            ModeBtn.Text = LockMode == "Head" and "锁定目标：头部" or "锁定目标：身体"
        end
    end)

    -- 范围输入
    local RangeTip = new("TextLabel")
    RangeTip.Size = UDim2.new(0,110,0,24)
    RangeTip.Position = UDim2.new(0,10,0,126)
    RangeTip.BackgroundTransparency = 1
    RangeTip.TextColor3 = Color3.new(1,1,1)
    RangeTip.TextSize = 15
    RangeTip.Text = "锁定范围(1~500)"
    RangeTip.Parent = SettingPanel

    local RangeInput = new("TextBox")
    RangeInput.Size = UDim2.new(0,110,0,28)
    RangeInput.Position = UDim2.new(0,130,0,124)
    RangeInput.Text = tostring(AimRange)
    RangeInput.TextColor3 = Color3.new(0,0,0)
    RangeInput.BackgroundColor3 = Color3.new(0.9,0.9,0.9)
    RangeInput.Active = true
    RangeInput.Parent = SettingPanel
    RangeInput.FocusLost:Connect(function()
        local num = tonumber(RangeInput.Text)
        if num then
            AimRange = math.clamp(num, 1, 500)
            RangeInput.Text = tostring(AimRange)
        else
            RangeInput.Text = tostring(AimRange)
        end
    end)

    -- 范围圆圈
    local CircleFrame = new("Frame")
    CircleFrame.Size = UDim2.new(0, AimRange*2, 0, AimRange*2)
    CircleFrame.AnchorPoint = Vector2.new(0.5,0.5)
    CircleFrame.Position = UDim2.new(0.5,0,0.5,0)
    CircleFrame.BackgroundTransparency = 1
    CircleFrame.BorderSizePixel = 2
    CircleFrame.BorderColor3 = Color3.new(1,1,1)
    CircleFrame.Visible = false
    CircleFrame.Parent = g2

    -- 瞄准红线
    local AimLine = new("Frame")
    AimLine.Size = UDim2.new(0,2,0,0)
    AimLine.AnchorPoint = Vector2.new(0,0.5)
    AimLine.BackgroundColor3 = Color3.new(1,0,0)
    AimLine.Visible = false
    AimLine.Parent = g2

    -- 渲染循环低频率防扫描
    RunService.RenderStepped:Connect(function()
        if not AimbotEnable or not localHRP then
            CircleFrame.Visible = false
            AimLine.Visible = false
            return
        end
        CircleFrame.Size = UDim2.new(0, AimRange*2, 0, AimRange*2)
        CircleFrame.Visible = true
        local cam = Workspace.CurrentCamera
        local nearestTarget, nearestDist = nil, math.huge
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr ~= Players.LocalPlayer and plr.Character then
                local targetPart = LockMode == "Head" and plr.Character:FindFirstChild("Head") or plr.Character:FindFirstChild("Torso")
                if not targetPart then continue end
                local dist = (localHRP.Position - targetPart.Position).Magnitude
                if dist < AimRange and dist < nearestDist then
                    nearestDist = dist
                    nearestTarget = targetPart
                end
            end
        end
        if not nearestTarget then
            AimLine.Visible = false
            return
        end
        local targetScreen = cam:WorldToViewportPoint(nearestTarget.Position)
        local screenCenter = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
        local targetVec = Vector2.new(targetScreen.X, targetScreen.Y)
        local lineLength = (targetVec - screenCenter).Magnitude
        AimLine.Size = UDim2.new(0, lineLength, 0, 2)
        AimLine.Position = UDim2.new(0.5, screenCenter.X, 0.5, screenCenter.Y)
        AimLine.Rotation = math.deg(math.atan2(targetVec.Y - screenCenter.Y, targetVec.X - screenCenter.X))
        AimLine.Visible = true
    end)
end)

print("加载完成")
