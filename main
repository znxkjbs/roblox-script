task.spawn(function()
    local success, err = pcall(function()
        local Players = game:GetService("Players")
        local TweenService = game:GetService("TweenService")
        local UIS = game:GetService("UserInputService")
        local lp = Players.LocalPlayer

        local targetSpeed = 16
        local currentSpeed = 16
        local hum = nil

        -- 持续更新自身速度（平滑过渡）
        local function UpdateSpeed()
            local char = lp.Character
            if not char then return end
            hum = char:FindFirstChildOfClass("Humanoid")
            if not hum then return end

            if math.abs(currentSpeed - targetSpeed) > 1 then
                currentSpeed = currentSpeed + (targetSpeed - currentSpeed) * 0.25
            else
                currentSpeed = targetSpeed
            end
            hum.WalkSpeed = math.floor(currentSpeed)
        end

        -- 循环刷新
        task.spawn(function()
            while task.wait(0.05) do
                UpdateSpeed()
            end
        end)

        -- 角色重生时同步
        lp.CharacterAdded:Connect(function()
            task.wait(0.3)
            UpdateSpeed()
        end)

        -- ===== UI 工具 =====
        local function AddRound(obj, r)
            Instance.new("UICorner", obj).CornerRadius = UDim.new(0, r)
        end
        local function AddGrad(obj, c1, c2, rot)
            local g = Instance.new("UIGradient", obj)
            g.Color = ColorSequence.new{ColorSequenceKeypoint.new(0,c1), ColorSequenceKeypoint.new(1,c2)}
            g.Rotation = rot
        end
        local function AddHover(btn)
            local t1 = TweenService:Create(btn, TweenInfo.new(0.1), {Size = UDim2.new(1,-4,1,-4)})
            local t2 = TweenService:Create(btn, TweenInfo.new(0.1), {Size = UDim2.new(1,0,1,0)})
            btn.MouseEnter:Connect(function() t1:Play() end)
            btn.MouseLeave:Connect(function() t2:Play() end)
        end

        -- ===== ScreenGui =====
        local ScreenGui = Instance.new("ScreenGui")
        ScreenGui.Name = "LocalSpeedUI"
        ScreenGui.ResetOnSpawn = false
        ScreenGui.DisplayOrder = 99999999
        ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        ScreenGui.IgnoreGuiInset = true
        ScreenGui.Parent = lp.PlayerGui

        -- 悬浮开关按钮（可拖动）
        local ToggleBtn = Instance.new("TextButton")
        ToggleBtn.Size = UDim2.new(0, 120, 0, 40)
        ToggleBtn.Position = UDim2.new(0.55, 0, 0.30, 0)
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(30,30,45)
        ToggleBtn.BorderSizePixel = 0
        ToggleBtn.Text = "速度面板"
        ToggleBtn.TextColor3 = Color3.new(1,1,1)
        ToggleBtn.TextSize = 16
        ToggleBtn.Font = Enum.Font.GothamBold
        ToggleBtn.ZIndex = 99999999
        ToggleBtn.Active = true
        ToggleBtn.Selectable = true
        ToggleBtn.AutoButtonColor = false
        ToggleBtn.Parent = ScreenGui
        AddRound(ToggleBtn, 10)
        AddGrad(ToggleBtn, Color3.fromRGB(60,40,100), Color3.fromRGB(30,30,45), 90)
        AddHover(ToggleBtn)

        -- 主面板
        local MainPanel = Instance.new("Frame")
        MainPanel.Size = UDim2.new(0, 220, 0, 300)
        MainPanel.Position = UDim2.new(0.03, 0, 0.21, 0)
        MainPanel.BackgroundColor3 = Color3.fromRGB(12,12,20)
        MainPanel.BorderSizePixel = 0
        MainPanel.Visible = false
        MainPanel.Active = true
        MainPanel.ZIndex = 99999998
        MainPanel.Parent = ScreenGui
        AddRound(MainPanel, 14)

        -- 开关控制
        local panelOpen = false
        ToggleBtn.Activated:Connect(function()
            panelOpen = not panelOpen
            MainPanel.Visible = panelOpen
        end)

        -- 面板拖动逻辑（修复点击冲突）
        local dragToggle = false
        local toggleStartPos, toggleTouchStart
        local DRAG_THRESHOLD = 30

        ToggleBtn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragToggle = true
                toggleTouchStart = input.Position
                toggleStartPos = ToggleBtn.Position
            end
        end)

        UIS.InputChanged:Connect(function(input)
            if dragToggle then
                local delta = input.Position - toggleTouchStart
                ToggleBtn.Position = UDim2.new(
                    toggleStartPos.X.Scale, toggleStartPos.X.Offset + delta.X,
                    toggleStartPos.Y.Scale, toggleStartPos.Y.Offset + delta.Y
                )
            end
        end)

        ToggleBtn.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragToggle = false
                local totalDelta = (input.Position - toggleTouchStart).Magnitude
                if totalDelta < DRAG_THRESHOLD then
                    -- 短按才切换面板
                    panelOpen = not panelOpen
                    MainPanel.Visible = panelOpen
                end
            end
        end)

        -- 面板拖动
        local dragPanel = false
        local panelStartPos, panelTouchStart
        MainPanel.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragPanel = true
                panelTouchStart = input.Position
                panelStartPos = MainPanel.Position
            end
        end)
        UIS.InputChanged:Connect(function(input)
            if dragPanel then
                local delta = input.Position - panelTouchStart
                MainPanel.Position = UDim2.new(
                    panelStartPos.X.Scale, panelStartPos.X.Offset + delta.X,
                    panelStartPos.Y.Scale, panelStartPos.Y.Offset + delta.Y
                )
            end
        end)
        UIS.InputEnded:Connect(function()
            dragPanel = false
        end)

        -- 标题
        local Title = Instance.new("TextLabel")
        Title.Size = UDim2.new(1,-20,0,28)
        Title.Position = UDim2.new(0,10,0,8)
        Title.BackgroundColor3 = Color3.fromRGB(50,20,90)
        Title.Text = "本地移速"
        Title.TextColor3 = Color3.new(1,1,1)
        Title.TextSize = 18
        Title.Font = Enum.Font.GothamBold
        Title.Parent = MainPanel
        AddRound(Title, 8)

        -- 当前速度显示
        local SpeedLabel = Instance.new("TextLabel")
        SpeedLabel.Size = UDim2.new(1,-20,0,24)
        SpeedLabel.Position = UDim2.new(0,10,0,44)
        SpeedLabel.BackgroundTransparency = 1
        SpeedLabel.Text = "当前: 16"
        SpeedLabel.TextColor3 = Color3.fromRGB(200,200,255)
        SpeedLabel.TextSize = 14
        SpeedLabel.Font = Enum.Font.SourceSansBold
        SpeedLabel.Parent = MainPanel

        -- 速度按钮列表
        local speeds = {
            {name = "速度 1",   value = 1},
            {name = "速度 16",  value = 16},
            {name = "速度 32",  value = 32},
            {name = "速度 64",  value = 64},
            {name = "速度 100", value = 100},
            {name = "速度 150", value = 150},
        }

        for i, data in ipairs(speeds) do
            local yPos = 76 + (i-1)*38
            local Btn = Instance.new("TextButton")
            Btn.Size = UDim2.new(1,-20,0,34)
            Btn.Position = UDim2.new(0,10,0,yPos)
            Btn.BackgroundColor3 = Color3.fromRGB(30,30,45)
            Btn.BorderSizePixel = 0
            Btn.Text = data.name
            Btn.TextColor3 = Color3.new(1,1,1)
            Btn.TextSize = 14
            Btn.Font = Enum.Font.SourceSans
            Btn.AutoButtonColor = false
            Btn.Parent = MainPanel
            AddRound(Btn,7)
            AddHover(Btn)

            Btn.Activated:Connect(function()
                targetSpeed = data.value
                SpeedLabel.Text = "当前: "..data.value
                -- 立即应用一次
                if hum then
                    hum.WalkSpeed = data.value
                    currentSpeed = data.value
                end
                -- 点击反馈变色
                Btn.BackgroundColor3 = Color3.fromRGB(80,30,150)
                task.wait(0.1)
                Btn.BackgroundColor3 = Color3.fromRGB(30,30,45)
            end)
        end

        print("✅ 本地速度面板加载完成，点击悬浮按钮打开")
    end)
    if not success then
        warn("❌ 脚本错误："..tostring(err))
    end
end)
