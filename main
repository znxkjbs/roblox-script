local task = task
local delay = task.delay
local new = Instance.new
local getSvc = game:GetService

delay(0.3, function()
    local Players = getSvc("Players")
    local RunService = getSvc("RunService")
    local UserInputService = getSvc("UserInputService")
    local Workspace = getSvc("Workspace")
    local localPlr = Players.LocalPlayer
    local CoreGui = localPlr:WaitForChild("PlayerGui")
    local mouse = localPlr:GetMouse()

    local guiMain = new("ScreenGui")
    guiMain.Name = tostring(math.random(1000,9999))
    guiMain.ResetOnSpawn = false
    guiMain.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    guiMain.Parent = CoreGui

    local guiRender = new("ScreenGui")
    guiRender.Name = tostring(math.random(1000,9999))
    guiRender.ResetOnSpawn = false
    guiRender.AlwaysOnTop = true
    guiRender.Parent = CoreGui

    local AssistSwitch = false
    local LockPart = "Head"
    local OuterFOV = 380
    local InnerFOV = 180
    local PanelShow = false
    local localChar, localHRP

    local function RefreshSelf()
        localChar = localPlr.Character or localPlr.CharacterAdded:Wait()
        localHRP = localChar:WaitForChild("HumanoidRootPart")
    end
    RefreshSelf()
    localPlr.CharacterAdded:Connect(RefreshSelf)

    -- 可拖动悬浮按钮
    local FloatBtn = new("TextButton")
    FloatBtn.Size = UDim2.new(0, 60, 0, 60)
    FloatBtn.Position = UDim2.new(0.84, 0, 0.3, 0)
    FloatBtn.BackgroundColor3 = Color3.new(0.1,0.1,0.1)
    FloatBtn.BorderSizePixel = 3
    FloatBtn.BorderColor3 = Color3.new(0.7,0.7,0.7)
    FloatBtn.Text = "追踪"
    FloatBtn.TextColor3 = Color3.new(1,1,1)
    FloatBtn.Font = Enum.Font.SourceSansBold
    FloatBtn.TextSize = 16
    FloatBtn.Active = true
    FloatBtn.ZIndex = 999
    FloatBtn.Parent = guiMain

    local dragStart, btnOrigin, isDrag = nil, nil, false
    FloatBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            dragStart = input.Position
            btnOrigin = FloatBtn.Position
            isDrag = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragStart and input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - dragStart
            if math.abs(delta.X) > 12 or math.abs(delta.Y) > 12 then
                isDrag = true
                FloatBtn.Position = UDim2.new(btnOrigin.X.Scale, btnOrigin.X.Offset + delta.X, btnOrigin.Y.Scale, btnOrigin.Y.Offset + delta.Y)
            end
        end
    end)
    local function TogglePanel()
        PanelShow = not PanelShow
        SettingPanel.Visible = PanelShow
    end
    FloatBtn.MouseButton1Click:Connect(TogglePanel)
    FloatBtn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch and not isDrag then
            TogglePanel()
        end
        dragStart, isDrag = nil, false
    end)

    -- 设置面板
    local SettingPanel = new("Frame")
    SettingPanel.Size = UDim2.new(0, 260, 0, 320)
    SettingPanel.Position = UDim2.new(0.02,0,0.2,0)
    SettingPanel.BackgroundColor3 = Color3.new(0.08,0.08,0.08)
    SettingPanel.BorderSizePixel = 3
    SettingPanel.BorderColor3 = Color3.new(0.4,0.4,0.4)
    SettingPanel.Visible = false
    SettingPanel.Active = true
    SettingPanel.Parent = guiMain

    local Title = new("TextLabel")
    Title.Size = UDim2.new(0,240,0,26)
    Title.Position = UDim2.new(0,10,0,6)
    Title.BackgroundTransparency = 1
    Title.TextColor3 = Color3.new(1,1,1)
    Title.Font = Enum.Font.SourceSansBold
    Title.TextSize = 18
    Title.Text = "双层FOV射线追踪辅助"
    Title.Parent = SettingPanel

    -- 总开关
    local MainSwitch = new("TextButton")
    MainSwitch.Size = UDim2.new(0,240,0,34)
    MainSwitch.Position = UDim2.new(0,10,0,40)
    MainSwitch.BackgroundColor3 = Color3.new(0.2,0.2,0.2)
    MainSwitch.TextColor3 = Color3.new(1,1,1)
    MainSwitch.Text = "追踪辅助：关闭"
    MainSwitch.Font = Enum.Font.SourceSans
    MainSwitch.TextSize = 16
    MainSwitch.Active = true
    MainSwitch.Parent = SettingPanel
    local function ToggleAssist()
        AssistSwitch = not AssistSwitch
        MainSwitch.Text = AssistSwitch and "追踪辅助：开启" or "追踪辅助：关闭"
        MainSwitch.BackgroundColor3 = AssistSwitch and Color3.new(0,0.4,0) or Color3.new(0.2,0.2,0.2)
    end
    MainSwitch.MouseButton1Click:Connect(ToggleAssist)
    MainSwitch.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then ToggleAssist() end
    end)

    -- 锁定部位切换
    local ModeSwitch = new("TextButton")
    ModeSwitch.Size = UDim2.new(0,240,0,34)
    ModeSwitch.Position = UDim2.new(0,10,0,82)
    ModeSwitch.BackgroundColor3 = Color3.new(0.2,0.2,0.2)
    ModeSwitch.TextColor3 = Color3.new(1,1,1)
    ModeSwitch.Text = "锁定部位：头部"
    ModeSwitch.Font = Enum.Font.SourceSans
    ModeSwitch.TextSize = 16
    ModeSwitch.Active = true
    ModeSwitch.Parent = SettingPanel
    local function SwapLock()
        LockPart = LockPart == "Head" and "Torso" or "Head"
        ModeSwitch.Text = LockPart == "Head" and "锁定部位：头部" or "锁定部位：身体"
    end
    ModeSwitch.MouseButton1Click:Connect(SwapLock)
    ModeSwitch.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then SwapLock() end
    end)

    -- 外圈范围输入
    local OuterTip = new("TextLabel")
    OuterTip.Size = UDim2.new(0,110,0,24)
    OuterTip.Position = UDim2.new(0,10,0,126)
    OuterTip.BackgroundTransparency = 1
    OuterTip.TextColor3 = Color3.new(1,1,1)
    OuterTip.TextSize = 15
    OuterTip.Text = "外圈范围(1~500)"
    OuterTip.Parent = SettingPanel
    local OuterInput = new("TextBox")
    OuterInput.Size = UDim2.new(0,110,0,28)
    OuterInput.Position = UDim2.new(0,130,0,124)
    OuterInput.Text = tostring(OuterFOV)
    OuterInput.TextColor3 = Color3.new(0,0,0)
    OuterInput.BackgroundColor3 = Color3.new(0.9,0.9,0.9)
    OuterInput.Active = true
    OuterInput.Parent = SettingPanel
    OuterInput.FocusLost:Connect(function()
        local num = tonumber(OuterInput.Text)
        if num then OuterFOV = math.clamp(num,1,500) OuterInput.Text = tostring(OuterFOV) end
    end)

    -- 内圈范围输入
    local InnerTip = new("TextLabel")
    InnerTip.Size = UDim2.new(0,110,0,24)
    InnerTip.Position = UDim2.new(0,10,0,166)
    InnerTip.BackgroundTransparency = 1
    InnerTip.TextColor3 = Color3.new(1,1,1)
    InnerTip.TextSize = 15
    InnerTip.Text = "内圈锁定(1~500)"
    InnerTip.Parent = SettingPanel
    local InnerInput = new("TextBox")
    InnerInput.Size = UDim2.new(0,110,0,28)
    InnerInput.Position = UDim2.new(0,130,0,164)
    InnerInput.Text = tostring(InnerFOV)
    InnerInput.TextColor3 = Color3.new(0,0,0)
    InnerInput.BackgroundColor3 = Color3.new(0.9,0.9,0.9)
    InnerInput.Active = true
    InnerInput.Parent = SettingPanel
    InnerInput.FocusLost:Connect(function()
        local num = tonumber(InnerInput.Text)
        if num then InnerFOV = math.clamp(num,1,500) InnerInput.Text = tostring(InnerFOV) end
    end)

    -- 双层渲染圈
    local OuterCircle = new("Frame")
    OuterCircle.Size = UDim2.new(0, OuterFOV*2, 0, OuterFOV*2)
    OuterCircle.AnchorPoint = Vector2.new(0.5,0.5)
    OuterCircle.Position = UDim2.new(0.5,0,0.5,0)
    OuterCircle.BackgroundTransparency = 1
    OuterCircle.BorderSizePixel = 2
    OuterCircle.BorderColor3 = Color3.new(1,1,1)
    OuterCircle.Visible = false
    OuterCircle.Parent = guiRender

    local InnerCircle = new("Frame")
    InnerCircle.Size = UDim2.new(0, InnerFOV*2, 0, InnerFOV*2)
    InnerCircle.AnchorPoint = Vector2.new(0.5,0.5)
    InnerCircle.Position = UDim2.new(0.5,0,0.5,0)
    InnerCircle.BackgroundTransparency = 1
    InnerCircle.BorderSizePixel = 2
    InnerCircle.BorderColor3 = Color3.new(1,0,0)
    InnerCircle.Visible = false
    InnerCircle.Parent = guiRender

    local AimLine = new("Frame")
    AimLine.Size = UDim2.new(0,2,0,0)
    AimLine.AnchorPoint = Vector2.new(0,0.5)
    AimLine.BackgroundColor3 = Color3.new(1,0,0)
    AimLine.Visible = false
    AimLine.Parent = guiRender

    -- 核心逻辑：只吸附鼠标，不修改镜头
    RunService.RenderStepped:Connect(function()
        if not AssistSwitch or not localHRP then
            OuterCircle.Visible = false
            InnerCircle.Visible = false
            AimLine.Visible = false
            return
        end
        OuterCircle.Size = UDim2.new(0, OuterFOV*2, 0, OuterFOV*2)
        InnerCircle.Size = UDim2.new(0, InnerFOV*2, 0, InnerFOV*2)
        OuterCircle.Visible = true
        InnerCircle.Visible = true

        local cam = Workspace.CurrentCamera
        local screenCenter = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
        local nearestTarget, minDist = nil, math.huge
        local targetScreenPos = nil

        for _,player in ipairs(Players:GetPlayers()) do
            if player == localPlr then continue end
            if not player.Character then continue end
            local targetPart = player.Character:FindFirstChild(LockPart)
            if not targetPart then continue end
            local screenPos = cam:WorldToViewportPoint(targetPart.Position)
            local screenVec = Vector2.new(screenPos.X, screenPos.Y)
            local dist = (screenVec - screenCenter).Magnitude
            if dist < OuterFOV and dist < minDist then
                minDist = dist
                nearestTarget = targetPart
                targetScreenPos = screenVec
            end
        end

        if not nearestTarget then
            AimLine.Visible = false
            return
        end

        -- 绘制指向红线
        local lineLen = (targetScreenPos - screenCenter).Magnitude
        AimLine.Size = UDim2.new(0, lineLen, 0, 2)
        AimLine.Position = UDim2.new(0.5, screenCenter.X, 0.5, screenCenter.Y)
        AimLine.Rotation = math.deg(math.atan2(targetScreenPos.Y - screenCenter.Y, targetScreenPos.X - screenCenter.X))
        AimLine.Visible = true

        -- 仅内圈吸附鼠标，无镜头修改
        if minDist < InnerFOV then
            mouse.X = targetScreenPos.X
            mouse.Y = targetScreenPos.Y
        end
    end)
end)

print("双层FOV射线追踪辅助加载完成｜无自动镜头自瞄")
