-- 高危远程发包脚本，极易封号，仅漏洞游戏可用
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local lp = Players.LocalPlayer

-- 替换成游戏内真实远程事件名称，找不到就无效
local Remote = ReplicatedStorage:FindFirstChild("SetWalkSpeedEvent")
if not Remote then
    warn("未找到远程事件，远程功能失效")
    return
end

-- 给指定玩家真实改速度（服务器同步，所有人可见）
local function SetTargetPlayerSpeed(targetName, speed)
    local targetPlr = Players:FindFirstChild(targetName)
    if not targetPlr then return end
    -- 发包给服务器修改他人属性
    Remote:FireServer(targetPlr, speed)
end

-- 示例：SetTargetPlayerSpeed("玩家名字", 80)
