-- 混淆防检测底层
local task = task
local delay = task.delay
local new = Instance.new
local getSvc = game:GetService

-- 延迟0.3秒加载规避开局扫描
delay(0.3, function()
    local Players = getSvc("Players")
    local RunService = getSvc("RunService")
    local UserInputService = getSvc("UserInputService")
    local Workspace = getSvc("Workspace")
    local localPlr = Players.LocalPlayer
    local CoreGui = localPlr:WaitForChild("PlayerGui")

    -- 随机命名GUI消除特征
    local guiMain = new("ScreenGui")
    guiMain.Name = tostring(math.random(1000,9999))
    guiMain.ResetOnSpawn = false
    guiMain.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    guiMain.Parent = CoreGui

    local guiRender = new("ScreenGui")
    guiRender.Name = tostring(math.random(1000,9999))
    guiRender.ResetOnSpawn = false
    guiRender.AlwaysOnTop = true
    guiRender.Parent = CoreGui

    -- 功能控制变量
    local AimbotOn = false
    local LockTarget = "Head"
    local FovSize = 300 -- 1~500屏幕FOV圈范围
    local PanelShow = false
    local localChar, localHRP

    -- 刷新自身角色根部件
    local function RefreshPlayer()
        localChar = localPlr.Character or localPlr.CharacterAdded:Wait()
        localHRP = localChar:WaitForChild("HumanoidRootPart")
    end
    RefreshPlayer()
    localPlr.CharacterAdded:Connect(RefreshPlayer)

    -- 可拖动圆形悬浮按钮
    local FloatBtn = new("TextButton")
    FloatBtn.Size = UDim2.new(0, 60, 0, 60)
    FloatBtn.Position = UDim2.new(0.84, 0, 0.3, 0)
    FloatBtn.BackgroundColor3 = Color3.new(0.1,0.1,0.1)
    FloatBtn.BorderSizePixel = 3
    FloatBtn.BorderColor3 = Color3.new(0.7,0.7,0.7)
    FloatBtn.Text = "瞄准"
    FloatBtn.TextColor3 = Color3.new(1,1,1)
    FloatBtn.Font = Enum.Font.SourceSansBold
    FloatBtn.TextSize = 16
    FloatBtn.Active = true
    FloatBtn.ZIndex = 999
    FloatBtn.Parent = guiMain

    local dragStart, btnOrigin, isDrag = nil, nil, false
    FloatBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            dragStart = input.Position
            btnOrigin = FloatBtn.Position
            isDrag = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragStart and input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - dragStart
            if math.abs(delta.X) > 12 or math.abs(delta.Y) > 12 then
                isDrag = true
                FloatBtn.Position = UDim2.new(btnOrigin.X.Scale, btnOrigin.X.Offset + delta.X, btnOrigin.Y.Scale, btnOrigin.Y.Offset + delta.Y)
            end
        end
    end)
    -- 双兼容触摸点击，修复点了没反应
    FloatBtn.MouseButton1Click:Connect(function()
        PanelShow = not PanelShow
        SettingPanel.Visible = PanelShow
    end)
    FloatBtn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch and not isDrag then
            PanelShow = not PanelShow
            SettingPanel.Visible = PanelShow
        end
        dragStart, isDrag = nil, false
    end)

    -- 设置面板
    local SettingPanel = new("Frame")
    SettingPanel.Size = UDim2.new(0, 260, 0, 280)
    SettingPanel.Position = UDim2.new(0.02,0,0.2,0)
    SettingPanel.BackgroundColor3 = Color3.new(0.08,0.08,0.08)
    SettingPanel.BorderSizePixel = 3
    SettingPanel.BorderColor3 = Color3.new(0.4,0.4,0.4)
    SettingPanel.Visible = false
    SettingPanel.Active = true
    SettingPanel.Parent = guiMain

    local Title = new("TextLabel")
    Title.Size = UDim2.new(0,240,0,26)
    Title.Position = UDim2.new(0,10,0,6)
    Title.BackgroundTransparency = 1
    Title.TextColor3 = Color3.new(1,1,1)
    Title.Font = Enum.Font.SourceSansBold
    Title.TextSize = 18
    Title.Text = "FOV范围瞄准设置"
    Title.Parent = SettingPanel

    -- 总开关（双触摸兼容）
    local SwitchAll = new("TextButton")
    SwitchAll.Size = UDim2.new(0,240,0,34)
    SwitchAll.Position = UDim2.new(0,10,0,40)
    SwitchAll.BackgroundColor3 = Color3.new(0.2,0.2,0.2)
    SwitchAll.TextColor3 = Color3.new(1,1,1)
    SwitchAll.Text = "瞄准功能：关闭"
    SwitchAll.Font = Enum.Font.SourceSans
    SwitchAll.TextSize = 16
    SwitchAll.Active = true
    SwitchAll.Parent = SettingPanel
    local function ToggleAim()
        AimbotOn = not AimbotOn
        if AimbotOn then
            SwitchAll.Text = "瞄准功能：开启"
            SwitchAll.BackgroundColor3 = Color3.new(0,0.4,0)
        else
            SwitchAll.Text = "瞄准功能：关闭"
            SwitchAll.BackgroundColor3 = Color3.new(0.2,0.2,0.2)
        end
    end
    SwitchAll.MouseButton1Click:Connect(ToggleAim)
    SwitchAll.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then ToggleAim() end
    end)

    -- 头部/身体切换
    local SwitchMode = new("TextButton")
    SwitchMode.Size = UDim2.new(0,240,0,34)
    SwitchMode.Position = UDim2.new(0,10,0,82)
    SwitchMode.BackgroundColor3 = Color3.new(0.2,0.2,0.2)
    SwitchMode.TextColor3 = Color3.new(1,1,1)
    SwitchMode.Text = "锁定目标：头部"
    SwitchMode.Font = Enum.Font.SourceSans
    SwitchMode.TextSize = 16
    SwitchMode.Active = true
    SwitchMode.Parent = SettingPanel
    local function SwapLock()
        LockTarget = LockTarget == "Head" and "Torso" or "Head"
        SwitchMode.Text = LockTarget == "Head" and "锁定目标：头部" or "锁定目标：身体"
    end
    SwitchMode.MouseButton1Click:Connect(SwapLock)
    SwitchMode.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then SwapLock() end
    end)

    -- FOV范围文字
    local RangeTip = new("TextLabel")
    RangeTip.Size = UDim2.new(0,110,0,24)
    RangeTip.Position = UDim2.new(0,10,0,126)
    RangeTip.BackgroundTransparency = 1
    RangeTip.TextColor3 = Color3.new(1,1,1)
    RangeTip.TextSize = 15
    RangeTip.Text = "FOV范围(1~500)"
    RangeTip.Parent = SettingPanel

    -- FOV输入框
    local RangeInput = new("TextBox")
    RangeInput.Size = UDim2.new(0,110,0,28)
    RangeInput.Position = UDim2.new(0,130,0,124)
    RangeInput.Text = tostring(FovSize)
    RangeInput.TextColor3 = Color3.new(0,0,0)
    RangeInput.BackgroundColor3 = Color3.new(0.9,0.9,0.9)
    RangeInput.Active = true
    RangeInput.Parent = SettingPanel
    RangeInput.FocusLost:Connect(function()
        local num = tonumber(RangeInput.Text)
        if num then
            FovSize = math.clamp(num, 1, 500)
            RangeInput.Text = tostring(FovSize)
        else
            RangeInput.Text = tostring(FovSize)
        end
    end)

    -- 屏幕中心FOV圆圈
    local FovCircle = new("Frame")
    FovCircle.Size = UDim2.new(0, FovSize*2, 0, FovSize*2)
    FovCircle.AnchorPoint = Vector2.new(0.5,0.5)
    FovCircle.Position = UDim2.new(0.5,0,0.5,0)
    FovCircle.BackgroundTransparency = 1
    FovCircle.BorderSizePixel = 2
    FovCircle.BorderColor3 = Color3.new(1,1,1)
    FovCircle.Visible = false
    FovCircle.Parent = guiRender

    -- 瞄准红线
    local AimLine = new("Frame")
    AimLine.Size = UDim2.new(0,2,0,0)
    AimLine.AnchorPoint = Vector2.new(0,0.5)
    AimLine.BackgroundColor3 = Color3.new(1,0,0)
    AimLine.Visible = false
    AimLine.Parent = guiRender

    -- 修复核心：屏幕FOV判断+自动相机锁定子弹追踪
    RunService.RenderStepped:Connect(function()
        -- 关闭瞄准直接隐藏所有渲染，无后台运算
        if not AimbotOn or not localHRP then
            FovCircle.Visible = false
            AimLine.Visible = false
            return
        end
        FovCircle.Size = UDim2.new(0, FovSize*2, 0, FovSize*2)
        FovCircle.Visible = true
        local cam = Workspace.CurrentCamera
        local screenCenter = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
        local nearestTarget, minScreenDist = nil, math.huge

        -- 遍历所有玩家筛选屏幕圈内目标
        for _,player in ipairs(Players:GetPlayers()) do
            if player ~= localPlr and player.Character then
                local targetPart = LockTarget == "Head" and player.Character:FindFirstChild("Head") or player.Character:FindFirstChild("Torso")
                if not targetPart then continue end
                -- 转屏幕坐标，判断是否在FOV圆圈内（修复之前只判断世界距离导致失效）
                local screenPos = cam:WorldToViewportPoint(targetPart.Position)
                local screenVec = Vector2.new(screenPos.X, screenPos.Y)
                local screenDist = (screenVec - screenCenter).Magnitude
                if screenDist < FovSize and screenDist < minScreenDist then
                    minScreenDist = screenDist
                    nearestTarget = targetPart
                end
            end
        end

        -- 无圈内目标隐藏红线、不锁镜头
        if not nearestTarget then
            AimLine.Visible = false
            return
        end

        -- 自动锁定相机，实现子弹追踪（你要的追踪效果）
        cam.CFrame = CFrame.new(cam.Position, nearestTarget.Position)

        -- 绘制中心指向红线
        local targetScreen = cam:WorldToViewportPoint(nearestTarget.Position)
        local targetVec = Vector2.new(targetScreen.X, targetScreen.Y)
        local lineLen = (targetVec - screenCenter).Magnitude
        AimLine.Size = UDim2.new(0, lineLen, 0, 2)
        AimLine.Position = UDim2.new(0.5, screenCenter.X, 0.5, screenCenter.Y)
        AimLine.Rotation = math.deg(math.atan2(targetVec.Y - screenCenter.Y, targetVec.X - screenCenter.X))
        AimLine.Visible = true
    end)
end)

print("远程FOV瞄准脚本加载完成")
