--[[
  严苛版：只捡名字同时含 "money" 和 "printer" 的物品
  强制过滤商店/Health/Mobile/Play等路径
  1秒换服（带随机抖动）
  全自动循环
--]]
local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local TweenService = game:GetService("TweenService")
local player = Players.LocalPlayer
local placeId = game.PlaceId
local currentJobId = game.JobId

local CONFIG = {
    MinInterval = 0.9,
    MaxInterval = 1.1,
    TweenDuration = 0.4,
    PickupDelay = 0.1,
    Offset = Vector3.new(1.2, 0, 0)
}

local PATH_BLACKLIST = {"shop", "store", "menu", "health", "mobile", "play", "character", "backpack"}

local function disableLocalAntiCheat()
    local guiRoots = {player:WaitForChild("PlayerGui"), game:GetService("CoreGui")}
    for _, root in ipairs(guiRoots) do
        for _, child in ipairs(root:GetChildren()) do
            local name = child.Name:lower()
            if name:find("anti") or name:find("cheat") or name:find("ban") or 
               name:find("sec") or name:find("moder") or name:find("detect") then
                pcall(function() child:Destroy() end)
            end
        end
    end
end

local function findMoneyPrinter()
    local target = nil
    local function search(instance)
        if target then return end
        local fullPath = instance:GetFullName():lower()
        for _, word in ipairs(PATH_BLACKLIST) do
            if fullPath:find(word) then return end
        end
        if instance:IsA("BasePart") or instance:IsA("Model") or instance:IsA("Tool") then
            local name = instance.Name:lower()
            if name:find("money") and name:find("printer") then
                local hasClick = instance:FindFirstChild("ClickDetector") or instance:FindFirstChildOfClass("ClickDetector")
                if hasClick or instance:IsA("Tool") then
                    target = instance
                    print("🎯 找到:", instance:GetFullName())
                    return
                end
            end
        end
        for _, child in ipairs(instance:GetChildren()) do
            search(child)
            if target then return end
        end
    end
    pcall(search, workspace)
    return target
end

local function findAndCollect()
    local target = findMoneyPrinter()
    if not target then
        print("❌ 未找到 Money Printer")
        return false
    end
    local targetPos = nil
    if target:IsA("Model") and target.PrimaryPart then
        targetPos = target.PrimaryPart.Position
    elseif target:IsA("BasePart") then
        targetPos = target.Position
    elseif target:IsA("Tool") and target:FindFirstChild("Handle") then
        targetPos = target.Handle.Position
    else
        for _, child in ipairs(target:GetDescendants()) do
            if child:IsA("BasePart") then
                targetPos = child.Position
                break
            end
        end
    end
    if not targetPos then return false end
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return false end
    local hrp = character.HumanoidRootPart
    local targetCFrame = CFrame.new(targetPos + CONFIG.Offset)
    local tweenInfo = TweenInfo.new(CONFIG.TweenDuration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
    local tween = TweenService:Create(hrp, tweenInfo, {CFrame = targetCFrame})
    tween:Play()
    tween.Completed:Wait()
    wait(CONFIG.PickupDelay)
    local clickDetector = target:FindFirstChild("ClickDetector") or target:FindFirstChildOfClass("ClickDetector")
    if clickDetector then
        pcall(function() clickDetector:FireClick(player) end)
        print("✅ 拾取成功")
        return true
    end
    if target:IsA("Tool") then
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid then
            pcall(function() humanoid:EquipTool(target) end)
            print("✅ 装备成功")
            return true
        end
    end
    print("✅ 已靠近")
    return true
end

local function hopToNewServer()
    local servers = {}
    local success, result = pcall(function()
        return TeleportService:GetServerList(placeId)
    end)
    if success and result then
        for _, server in ipairs(result) do
            if server.Id ~= currentJobId and server.PlayerCount < server.MaxPlayers then
                table.insert(servers, server)
            end
        end
    end
    if #servers > 0 then
        local target = servers[math.random(1, #servers)]
        pcall(function() TeleportService:TeleportToPlaceInstance(placeId, target.Id, player) end)
        print("🔄 跳转新服")
    else
        pcall(function() TeleportService:TeleportToPlaceInstance(placeId, currentJobId, player) end)
        print("🔄 刷新当前服")
    end
end

spawn(function()
    disableLocalAntiCheat()
    while true do
        repeat wait(0.3) until player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        wait(0.5)
        pcall(findAndCollect)
        local waitTime = math.random(CONFIG.MinInterval * 100, CONFIG.MaxInterval * 100) / 100
        print("⏳ 等待 " .. waitTime .. " 秒换服")
        wait(waitTime)
        pcall(hopToNewServer)
        currentJobId = game.JobId
        wait(0.3)
    end
end)

print("🔥 远程加载版已启动 | 只捡同时含 money 和 printer 的物品，跳过商店杂项")
