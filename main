task.spawn(function()
    local success, err = pcall(function()
        local Players = game:GetService("Players")
        local ReplicatedStorage = game:GetService("ReplicatedStorage")
        local TweenService = game:GetService("TweenService")
        local lp = Players.LocalPlayer
        local targetPlayerName = ""

        -- ⚠️ 改成游戏ReplicatedStorage里真实RemoteEvent名称
        local RemoteEventName = "SetWalkSpeedEvent"

        -- 自动查找远程事件，打印全部事件用于排查
        local function getRemote()
            local remote = ReplicatedStorage:FindFirstChild(RemoteEventName)
            if remote and remote:IsA("RemoteEvent") then
                return remote
            end
            warn("⚠️ 未找到远程事件 [" .. RemoteEventName .. "]，当前ReplicatedStorage内可用远程：")
            for _, child in ipairs(ReplicatedStorage:GetChildren()) do
                if child:IsA("RemoteEvent") then
                    warn("  远程事件: " .. child.Name)
                end
            end
            return nil
        end

        local Remote = getRemote()

        -- 远程发包函数（修复参数：统一传递玩家对象，适配绝大多数游戏服务端）
        local function RemoteSetTargetSpeed(playerName, speed)
            if not Remote then
                Remote = getRemote()
                if not Remote then
                    warn("[远程失败] 远程事件不存在")
                    return false
                end
            end

            local targetPlr = Players:FindFirstChild(playerName)
            if not targetPlr then
                warn("[远程失败] 玩家 [" .. playerName .. "] 不在房间")
                return false
            end

            local safeSpeed = math.clamp(speed, 1, 120)
            print("📤 发送远程: " .. Remote.Name, "目标玩家:", targetPlr.Name, "速度:", safeSpeed)

            local fireOk, fireErr = pcall(function()
                Remote:FireServer(targetPlr, safeSpeed) -- 标准传参：玩家对象+速度
            end)
            if not fireOk then
                warn("[远程发包报错] " .. tostring(fireErr))
                return false
            end
            print("✅ 发包完成")
            return true
        end

        -- ============ UI工具函数 ============
        local function AddRound(obj, r)
            local c = Instance.new("UICorner")
            c.CornerRadius = UDim.new(0, r)
            c.Parent = obj
        end
        local function AddShadow(obj, blur, x, y, trans)
            local s = Instance.new("UIShadow")
            s.Blur = blur
            s.Offset = Vector2.new(x, y)
            s.Transparency = trans
            s.Parent = obj
        end
        local function AddGrad(obj, c1, c2, rot)
            local g = Instance.new("UIGradient")
            g.Color = ColorSequence.new{ColorSequenceKeypoint.new(0,c1), ColorSequenceKeypoint.new(1,c2)}
            g.Rotation = rot
            g.Parent = obj
        end
        local function AddHover(btn)
            local t1 = TweenService:Create(btn, TweenInfo.new(0.1), {Size = UDim2.new(1,-4,1,-4)})
            local t2 = TweenService:Create(btn, TweenInfo.new(0.1), {Size = UDim2.new(1,0,1,0)})
            btn.MouseEnter:Connect(function() t1:Play() end)
            btn.MouseLeave:Connect(function() t2:Play() end)
        end

        -- ============ 顶层GUI（新增IgnoreGuiInset修复边缘遮挡） ============
        local ScreenGui = Instance.new("ScreenGui")
        ScreenGui.Name = "RemoteOnlyGUI"
        ScreenGui.ResetOnSpawn = false
        ScreenGui.DisplayOrder = 99999999
        ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        ScreenGui.IgnoreGuiInset = true -- 关键修复：突破手机安全边距，边缘按钮可点击
        ScreenGui.Parent = lp.PlayerGui

        -- 悬浮开关【调整位置，避开右侧摇杆遮挡区】
        local ToggleBtn = Instance.new("TextButton")
        ToggleBtn.Size = UDim2.new(0, 120, 0, 44)
        ToggleBtn.Position = UDim2.new(0.6, 0, 0.32, 0) -- 从0.76左移到0.6，远离右侧摇杆
        ToggleBtn.BackgroundColor3 = Color3.new(0.12,0.12,0.16)
        ToggleBtn.BorderSizePixel = 0
        ToggleBtn.Text = "功能开关"
        ToggleBtn.TextColor3 = Color3.new(1,1,1)
        ToggleBtn.TextSize = 16
        ToggleBtn.Font = Enum.Font.GothamBold
        ToggleBtn.ZIndex = 99999999
        ToggleBtn.Active = true
        ToggleBtn.Selectable = true
        ToggleBtn.Parent = ScreenGui
        AddRound(ToggleBtn, 10)
        AddShadow(ToggleBtn, 5, 2, 2, 0.4)
        AddGrad(ToggleBtn, Color3.new(0.18,0.18,0.28), Color3.new(0.1,0.1,0.14), 90)
        AddHover(ToggleBtn)

        -- 主面板
        local MainPanel = Instance.new("Frame")
        MainPanel.Size = UDim2.new(0, 300, 0, 360)
        MainPanel.Position = UDim2.new(0.02, 0, 0.21, 0)
        MainPanel.BackgroundColor3 = Color3.new(0.06,0.06,0.09)
        MainPanel.BorderSizePixel = 0
        MainPanel.Visible = false
        MainPanel.Active = true
        MainPanel.ZIndex = 99999998
        MainPanel.Parent = ScreenGui
        AddRound(MainPanel, 14)
        AddShadow(MainPanel, 10, 3, 3, 0.35)

        local panelOpen = false
        local function SwitchPanel()
            panelOpen = not panelOpen
            MainPanel.Visible = panelOpen
            print("【点击触发】面板状态:", panelOpen)
        end
        ToggleBtn.Activated:Connect(SwitchPanel)

        -- 标题
        local Title = Instance.new("TextLabel")
        Title.Size = UDim2.new(1,-20,0,32)
        Title.Position = UDim2.new(0,10,0,10)
        Title.BackgroundTransparency = 0
        Title.BackgroundColor3 = Color3.new(0.2,0.08,0.35)
        Title.Text = "远程玩家速度修改"
        Title.TextColor3 = Color3.new(1,1,1)
        Title.TextSize = 19
        Title.Font = Enum.Font.GothamBold
        Title.Parent = MainPanel
        AddRound(Title, 8)

        -- 名称输入框
        local NameInput = Instance.new("TextBox")
        NameInput.Size = UDim2.new(1,-20,0,36)
        NameInput.Position = UDim2.new(0,10,0,54)
        NameInput.BackgroundColor3 = Color3.new(0.1,0.1,0.16)
        NameInput.BorderSizePixel = 0
        NameInput.Text = "输入目标玩家完整ID"
        NameInput.TextColor3 = Color3.new(1,1,1)
        NameInput.TextSize = 15
        NameInput.Font = Enum.Font.SourceSans
        NameInput.Parent = MainPanel
        AddRound(NameInput, 7)
        NameInput.FocusLost:Connect(function()
            targetPlayerName = NameInput.Text
            print("已保存目标玩家名："..targetPlayerName)
        end)

        local Tip = Instance.new("TextLabel")
        Tip.Size = UDim2.new(1,-20,0,24)
        Tip.Position = UDim2.new(0,10,0,98)
        Tip.BackgroundTransparency = 1
        Tip.Text = "仅修改其他玩家，无本地加速功能"
        Tip.TextColor3 = Color3.new(1,0.4,0.4)
        Tip.TextSize = 14
        Tip.Parent = MainPanel

        -- 速度按钮生成
        local function MakeSpeedBtn(yOffset, name, val)
            local Btn = Instance.new("TextButton")
            Btn.Size = UDim2.new(1,-20,0,38)
            Btn.Position = UDim2.new(0,10,0,yOffset)
            Btn.BackgroundColor3 = Color3.new(0.12,0.12,0.18)
            Btn.BorderSizePixel = 0
            Btn.Text = name
            Btn.TextColor3 = Color3.new(1,1,1)
            Btn.TextSize = 15
            Btn.Font = Enum.Font.SourceSans
            Btn.Parent = MainPanel
            AddRound(Btn,7)
            AddHover(Btn)
            Btn.Activated:Connect(function()
                if targetPlayerName == "" then
                    warn("请先填写目标玩家ID！")
                    return
                end
                RemoteSetTargetSpeed(targetPlayerName, val)
                Btn.BackgroundColor3 = Color3.new(0.3,0.15,0.5)
                task.wait(0.12)
                Btn.BackgroundColor3 = Color3.new(0.12,0.12,0.18)
            end)
        end

        MakeSpeedBtn(130, "远程速度 30", 30)
        MakeSpeedBtn(176, "远程速度 80", 80)
        MakeSpeedBtn(222, "恢复默认16", 16)

        print("✅ 远程菜单加载完成")
        print("📌 当前使用远程事件: " .. RemoteEventName)
        if Remote then
            print("✔ 远程事件已识别，发包功能正常")
        else
            warn("❌ 未找到对应远程事件，请查看上方打印的可用事件名称修改代码")
        end
    end)
    if not success then
        warn("❌ 脚本报错："..tostring(err))
    end
end)
