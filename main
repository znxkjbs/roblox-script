local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")
local UserInputService = game:GetService("UserInputService")

local localPlr = Players.LocalPlayer
local localGui = Instance.new("ScreenGui")
localGui.Name = "FuncPanel"
localGui.ResetOnSpawn = false
localGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
localGui.Parent = localPlr:WaitForChild("PlayerGui")

-- 功能开关变量
local PlayerESP = false
local WalkJumpMod = false
local PanelVisible = false

-- 原版游戏速度数值
local defaultWalk = 16
local defaultJump = 50
local walkSpeedVal = 35
local jumpPowerVal = 75

local localChar, localHum

-- 刷新角色移速跳跃
local function RefreshChar()
    localChar = localPlr.Character or localPlr.CharacterAdded:Wait()
    localHum = localChar:WaitForChild("Humanoid")
    task.wait(0.03)
    if WalkJumpMod then
        localHum.WalkSpeed = walkSpeedVal
        localHum.JumpPower = jumpPowerVal
    else
        localHum.WalkSpeed = defaultWalk
        localHum.JumpPower = defaultJump
    end
end
RefreshChar()

-- 角色重生重载属性
localPlr.CharacterAdded:Connect(function()
    task.wait(0.08)
    RefreshChar()
end)

-- 低占用人物透视（不遍历墙体，防掉帧）
RunService.RenderStepped:Connect(function()
    if not PlayerESP then return end
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr ~= localPlr and plr.Character then
            for _,part in ipairs(plr.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.LocalTransparencyModifier = -0.9
                end
            end
        end
    end
end)

-- 关闭透视恢复玩家显示
local function ResetAllPlayerVis()
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr.Character then
            for _,part in ipairs(plr.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.LocalTransparencyModifier = 0
                end
            end
        end
    end
end

-- ===================== 可拖动悬浮小按钮（修复触摸点击无响应） =====================
local DragBtn = Instance.new("TextButton")
DragBtn.Size = UDim2.new(0, 55, 0, 55)
DragBtn.Position = UDim2.new(0.86, 0, 0.32, 0)
DragBtn.BackgroundColor3 = Color3.new(0.15,0.15,0.15)
DragBtn.BorderSizePixel = 2
DragBtn.BorderColor3 = Color3.new(0.6,0.6,0.6)
DragBtn.Text = "开关"
DragBtn.TextColor3 = Color3.new(1,1,1)
DragBtn.Font = Enum.Font.SourceSansBold
DragBtn.TextSize = 16
DragBtn.Active = true
DragBtn.Selectable = true
DragBtn.ZIndex = 999
DragBtn.Parent = localGui

local dragStart, btnOriginPos
local isDragging = false

-- 触摸按下判定（区分拖动和点击）
DragBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragStart = input.Position
        btnOriginPos = DragBtn.Position
        isDragging = false
    end
end)

-- 拖动移动逻辑
UserInputService.InputChanged:Connect(function(input)
    if dragStart and input.UserInputType == Enum.UserInputType.Touch then
        local offset = input.Position - dragStart
        -- 偏移超过15像素判定为拖动，不触发点击
        if math.abs(offset.X) > 15 or math.abs(offset.Y) > 15 then
            isDragging = true
            DragBtn.Position = UDim2.new(
                btnOriginPos.X.Scale,
                btnOriginPos.X.Offset + offset.X,
                btnOriginPos.Y.Scale,
                btnOriginPos.Y.Offset + offset.Y
            )
        end
    end
end)

-- 触摸松开：没拖动则切换面板显示隐藏
DragBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch and not isDragging then
        PanelVisible = not PanelVisible
        MainFrame.Visible = PanelVisible
    end
    dragStart = nil
    isDragging = false
end)

-- ===================== 主功能面板（默认隐藏） =====================
local MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0,240,0,220)
MainFrame.Position = UDim2.new(0.01,0,0.25,0)
MainFrame.BackgroundColor3 = Color3.new(0.1,0.1,0.1)
MainFrame.BorderSizePixel = 3
MainFrame.BorderColor3 = Color3.new(0.35,0.35,0.35)
MainFrame.Visible = false
MainFrame.Active = true
MainFrame.Parent = localGui

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(0,220,0,24)
Title.Position = UDim2.new(0,10,0,6)
Title.BackgroundTransparency = 1
Title.TextColor3 = Color3.new(1,1,1)
Title.Font = Enum.Font.SourceSansBold
Title.TextSize = 18
Title.Text = "功能开关面板"
Title.Parent = MainFrame

-- 人物透视按钮
local ESPBtn = Instance.new("TextButton")
ESPBtn.Size = UDim2.new(0,220,0,32)
ESPBtn.Position = UDim2.new(0,10,0,36)
ESPBtn.BackgroundColor3 = Color3.new(0.2,0.2,0.2)
ESPBtn.TextColor3 = Color3.new(1,1,1)
ESPBtn.Font = Enum.Font.SourceSans
ESPBtn.TextSize = 16
ESPBtn.Text = "人物透视：关闭"
ESPBtn.Active = true
ESPBtn.Parent = MainFrame

ESPBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        PlayerESP = not PlayerESP
        if PlayerESP then
            ESPBtn.Text = "人物透视：开启"
            ESPBtn.BackgroundColor3 = Color3.new(0,0.4,0)
        else
            ESPBtn.Text = "人物透视：关闭"
            ESPBtn.BackgroundColor3 = Color3.new(0.2,0.2,0.2)
            ResetAllPlayerVis()
        end
    end
end)

-- 移速跳跃开关按钮
local StatBtn = Instance.new("TextButton")
StatBtn.Size = UDim2.new(0,220,0,32)
StatBtn.Position = UDim2.new(0,10,0,74)
StatBtn.BackgroundColor3 = Color3.new(0.2,0.2,0.2)
StatBtn.TextColor3 = Color3.new(1,1,1)
StatBtn.Font = Enum.Font.SourceSans
StatBtn.TextSize = 16
StatBtn.Text = "移速跳跃修改：关闭"
StatBtn.Active = true
StatBtn.Parent = MainFrame

StatBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        WalkJumpMod = not WalkJumpMod
        if WalkJumpMod then
            StatBtn.Text = "移速跳跃修改：开启"
            StatBtn.BackgroundColor3 = Color3.new(0,0.4,0)
            localHum.WalkSpeed = walkSpeedVal
            localHum.JumpPower = jumpPowerVal
        else
            StatBtn.Text = "移速跳跃修改：关闭"
            StatBtn.BackgroundColor3 = Color3.new(0.2,0.2,0.2)
            localHum.WalkSpeed = defaultWalk
            localHum.JumpPower = defaultJump
        end
    end
end)

-- 移速输入框
local SpeedTip = Instance.new("TextLabel")
SpeedTip.Size = UDim2.new(0,100,0,22)
SpeedTip.Position = UDim2.new(0,10,0,112)
SpeedTip.BackgroundTransparency = 1
SpeedTip.TextColor3 = Color3.new(1,1,1)
SpeedTip.TextSize = 15
SpeedTip.Text = "移速(1-500)"
SpeedTip.Parent = MainFrame

local SpeedInput = Instance.new("TextBox")
SpeedInput.Size = UDim2.new(0,110,0,26)
SpeedInput.Position = UDim2.new(0,120,0,110)
SpeedInput.Text = tostring(walkSpeedVal)
SpeedInput.TextColor3 = Color3.new(0,0,0)
SpeedInput.Active = true
SpeedInput.Parent = MainFrame

SpeedInput.FocusLost:Connect(function()
    local num = tonumber(SpeedInput.Text)
    if num then
        walkSpeedVal = math.clamp(num,1,500)
        SpeedInput.Text = tostring(walkSpeedVal)
        if WalkJumpMod then
            localHum.WalkSpeed = walkSpeedVal
        end
    else
        SpeedInput.Text = tostring(walkSpeedVal)
    end
end)

-- 跳跃输入框
local JumpTip = Instance.new("TextLabel")
JumpTip.Size = UDim2.new(0,100,0,22)
JumpTip.Position = UDim2.new(0,10,0,148)
JumpTip.BackgroundTransparency = 1
JumpTip.TextColor3 = Color3.new(1,1,1)
JumpTip.TextSize = 15
JumpTip.Text = "跳跃(1-300)"
JumpTip.Parent = MainFrame

local JumpInput = Instance.new("TextBox")
JumpInput.Size = UDim2.new(0,110,0,26)
JumpInput.Position = UDim2.new(0,120,0,146)
JumpInput.Text = tostring(jumpPowerVal)
JumpInput.TextColor3 = Color3.new(0,0,0)
JumpInput.Active = true
JumpInput.Parent = MainFrame

JumpInput.FocusLost:Connect(function()
    local num = tonumber(JumpInput.Text)
    if num then
        jumpPowerVal = math.clamp(num,1,300)
        JumpInput.Text = tostring(jumpPowerVal)
        if WalkJumpMod then
            localHum.JumpPower = jumpPowerVal
        end
    else
        JumpInput.Text = tostring(jumpPowerVal)
    end
end)

print("忍者注入器触摸点击修复版加载完成")
