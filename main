local task = task
local delay = task.delay
local new = Instance.new
local getSvc = game:GetService

delay(0.3, function()
    local UserInputService = getSvc("UserInputService")
    local localPlayer = game:GetService("Players").LocalPlayer
    local coreGui = localPlayer:WaitForChild("PlayerGui")

    -- 仅单个UI容器
    local mainUI = new("ScreenGui")
    mainUI.Name = tostring(math.random(1000,9999))
    mainUI.ResetOnSpawn = false
    mainUI.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    mainUI.Parent = coreGui

    -- 全局面板状态
    local panelVisible = false
    local panelScale = 1

    -- 长方形悬浮开关按钮
    local toggleFloatBtn = new("TextButton")
    toggleFloatBtn.Size = UDim2.new(0, 120, 0, 40)
    toggleFloatBtn.Position = UDim2.new(0.82, 0, 0.3, 0)
    toggleFloatBtn.BackgroundColor3 = Color3.new(0.15,0.15,0.15)
    toggleFloatBtn.BorderSizePixel = 2
    toggleFloatBtn.BorderColor3 = Color3.new(0.6,0.6,0.6)
    toggleFloatBtn.Text = "功能开关"
    toggleFloatBtn.TextColor3 = Color3.new(1,1,1)
    toggleFloatBtn.Font = Enum.Font.SourceSansBold
    toggleFloatBtn.TextSize = 16
    toggleFloatBtn.Active = true
    toggleFloatBtn.ZIndex = 999
    toggleFloatBtn.Parent = mainUI

    local dragStartPos, btnOriginPos, dragging = nil, nil, false
    toggleFloatBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            dragStartPos = input.Position
            btnOriginPos = toggleFloatBtn.Position
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragStartPos and input.UserInputType == Enum.UserInputType.Touch then
            local offset = input.Position - dragStartPos
            if math.abs(offset.X) > 12 or math.abs(offset.Y) > 12 then
                dragging = true
                toggleFloatBtn.Position = UDim2.new(btnOriginPos.X.Scale, btnOriginPos.X.Offset + offset.X, btnOriginPos.Y.Scale, btnOriginPos.Y.Offset + offset.Y)
            end
        end
    end)
    local function switchPanel()
        panelVisible = not panelVisible
        mainPanel.Visible = panelVisible
    end
    toggleFloatBtn.MouseButton1Click:Connect(switchPanel)
    toggleFloatBtn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch and not dragging then
            switchPanel()
        end
        dragStartPos, dragging = nil, false
    end)

    -- 主面板容器
    local mainPanel = new("Frame")
    mainPanel.Size = UDim2.new(0, 300, 0, 400)
    mainPanel.Position = UDim2.new(0.02,0,0.2,0)
    mainPanel.BackgroundColor3 = Color3.new(0.07,0.07,0.07)
    mainPanel.BorderSizePixel = 3
    mainPanel.BorderColor3 = Color3.new(0.35,0.35,0.35)
    mainPanel.Visible = false
    mainPanel.Active = true
    mainPanel.ZIndex = 998
    mainPanel.Parent = mainUI

    -- 右上角 + 放大按钮
    local zoomAdd = new("TextButton")
    zoomAdd.Size = UDim2.new(0, 30, 0, 30)
    zoomAdd.Position = UDim2.new(1, -65, 0, 5)
    zoomAdd.BackgroundColor3 = Color3.new(0.2,0.2,0.2)
    zoomAdd.Text = "+"
    zoomAdd.TextColor3 = Color3.new(1,1,1)
    zoomAdd.Font = Enum.Font.SourceSansBold
    zoomAdd.TextSize = 18
    zoomAdd.Parent = mainPanel
    zoomAdd.MouseButton1Click:Connect(function()
        panelScale = math.clamp(panelScale + 0.1, 0.6, 1.6)
        mainPanel.Size = UDim2.new(0, 300 * panelScale, 0, 400 * panelScale)
    end)

    -- 右上角 - 缩小按钮
    local zoomSub = new("TextButton")
    zoomSub.Size = UDim2.new(0, 30, 0, 30)
    zoomSub.Position = UDim2.new(1, -30, 0, 5)
    zoomSub.BackgroundColor3 = Color3.new(0.2,0.2,0.2)
    zoomSub.Text = "-"
    zoomSub.TextColor3 = Color3.new(1,1,1)
    zoomSub.Font = Enum.Font.SourceSansBold
    zoomSub.TextSize = 18
    zoomSub.Parent = mainPanel
    zoomSub.MouseButton1Click:Connect(function()
        panelScale = math.clamp(panelScale - 0.1, 0.6, 1.6)
        mainPanel.Size = UDim2.new(0, 300 * panelScale, 0, 400 * panelScale)
    end)

    -- 面板标题
    local titleLabel = new("TextLabel")
    titleLabel.Size = UDim2.new(0,240,0,26)
    titleLabel.Position = UDim2.new(0.05,0,0,8)
    titleLabel.BackgroundTransparency = 1
    titleLabel.TextColor3 = Color3.new(1,1,1)
    titleLabel.Font = Enum.Font.SourceSansBold
    titleLabel.TextSize = 18
    titleLabel.Text = "设置面板"
    titleLabel.Parent = mainPanel

    -- 右下角 模式按钮（默认通用）
    local modeBtn = new("TextButton")
    modeBtn.Size = UDim2.new(0, 100, 0, 32)
    modeBtn.Position = UDim2.new(0.05,0,0.75,0)
    modeBtn.BackgroundColor3 = Color3.new(0.2,0.2,0.2)
    modeBtn.TextColor3 = Color3.new(1,1,1)
    modeBtn.Text = "模式：通用"
    modeBtn.Font = Enum.Font.SourceSans
    modeBtn.TextSize = 14
    modeBtn.Parent = mainPanel

    -- 玩家名字输入框
    local nameTip = new("TextLabel")
    nameTip.Size = UDim2.new(0,90,0,24)
    nameTip.Position = UDim2.new(0.4,0,0.75,0)
    nameTip.BackgroundTransparency = 1
    nameTip.TextColor3 = Color3.new(1,1,1)
    nameTip.TextSize = 14
    nameTip.Text = "玩家名称"
    nameTip.Parent = mainPanel

    local nameInput = new("TextBox")
    nameInput.Size = UDim2.new(0,130,0,28)
    nameInput.Position = UDim2.new(0.4,0,0.82,0)
    nameInput.Text = ""
    nameInput.TextColor3 = Color3.new(0,0,0)
    nameInput.BackgroundColor3 = Color3.new(0.9,0.9,0.9)
    nameInput.Active = true
    nameInput.Parent = mainPanel
end)
print("纯UI界面加载完成，无任何追踪功能逻辑")

-- 移速控制函数（防报错优化）
local function SetWalkSpeed(speed)
    local lp = game.Players.LocalPlayer
    local char = lp.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.WalkSpeed = speed
    end
end

-- 飞行脚本加载（国内镜像加速，捕获错误不崩溃）
local function LoadFlyV3()
    local flyUrl = "https://mirror.ghproxy.com/https://raw.githubusercontent.com/mciklw/mciklwscript/refs/heads/main/flyvthree"
    local ok, err = pcall(function()
        loadstring(game:HttpGet(flyUrl))()
    end)
    if not ok then
        warn("飞行脚本加载失败："..tostring(err))
    end
end
